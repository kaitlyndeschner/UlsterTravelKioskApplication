<Window x:Class="UlsterTravelKioskApplication.UI.Screens.AirportScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UlsterTravelKioskApplication.UI.Screens"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="Airport Screen"
        Height="450"
        Width="800"
        Background="#FFF2F4F6">

    <Window.Resources>

        <!-- palette brushes used across the app so the ui stays consistent -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3F6178"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5F7F92"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2F4C5C"/>

        <!-- surface brushes used for cards, borders, and input backgrounds -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD2D9E0"/>

        <!-- text colours for headings and secondary text -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7280"/>

        <!-- confirm button colours to visually show a positive action -->
        <SolidColorBrush x:Key="ConfirmBrush" Color="#4A766D"/>
        <SolidColorBrush x:Key="ConfirmHoverBrush" Color="#5A8A80"/>
        <SolidColorBrush x:Key="ConfirmPressedBrush" Color="#3B5E57"/>

        <!-- reset button colours so it looks different from confirm -->
        <SolidColorBrush x:Key="ResetBrush" Color="#556A73"/>
        <SolidColorBrush x:Key="ResetHoverBrush" Color="#667D87"/>
        <SolidColorBrush x:Key="ResetPressedBrush" Color="#44565D"/>

        <!-- exit button colours so it stands out as a stronger action -->
        <SolidColorBrush x:Key="ExitBrush" Color="#4F3E46"/>
        <SolidColorBrush x:Key="ExitHoverBrush" Color="#604B55"/>
        <SolidColorBrush x:Key="ExitPressedBrush" Color="#3A2F35"/>

        <!-- shadow effect used to make groupboxes look like cards -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="3"
                          Opacity="0.18"/>

        <!-- base button style shared by most buttons on this screen -->
        <Style x:Key="PrimaryMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#2B4553"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <!-- controltemplate used to get rounded corners and hover/pressed effects -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- changes background when mouse is over the button -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>

                            <!-- changes background when the button is pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>

                            <!-- makes disabled buttons look faded -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- confirm button is based on primary style but uses green colours -->
        <Style x:Key="ConfirmButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ConfirmBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ConfirmPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- reset button is based on primary style but uses grey colours -->
        <Style x:Key="ResetButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ResetBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ResetPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ResetHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ResetPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- exit button is based on primary style but uses darker colours -->
        <Style x:Key="ExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ExitBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ExitPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- combobox style for a modern input look -->
        <Style x:Key="ComboBoxModernStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- groupbox template to make sections look like rounded cards -->
        <Style x:Key="CardGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Effect="{StaticResource CardShadow}"
                                Padding="14"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- header label for the groupbox -->
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="2,0,0,10"/>

                                <!-- content presenter holds the controls inside the groupbox -->
                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- listbox style so the routes list matches the card look -->
        <Style x:Key="RoutesListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- title row -->
            <RowDefinition Height="Auto"/>
            <!-- selector row -->
            <RowDefinition Height="*"/>
            <!-- list row -->
            <RowDefinition Height="Auto"/>
            <!-- details row -->
            <RowDefinition Height="Auto"/>
            <!-- back/exit row -->
        </Grid.RowDefinitions>

        <!-- title area with an icon and heading -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       Text="&#xE707;"
                       FontSize="20"
                       Margin="0,0,8,0"/>
            <TextBlock Text="Airports"
                       FontSize="22"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <!-- airport selector and action buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- combobox fills remaining space -->
                <ColumnDefinition Width="Auto"/>
                <!-- confirm button -->
                <ColumnDefinition Width="Auto"/>
                <!-- reset button -->
            </Grid.ColumnDefinitions>

            <!-- combobox binds to a list of airport objects in code behind -->
            <!-- selectedvaluepath makes selectedvalue return airportcode -->
            <ComboBox x:Name="comboboxAirports"
                      Style="{StaticResource ComboBoxModernStyle}"
                      SelectedValuePath="AirportCode">

                <!-- itemtemplate controls how each airport appears in the dropdown -->
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding AirportName}" />
                            <Run Text=" (" />
                            <Run Text="{Binding AirportCode}" />
                            <Run Text=")" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- confirm triggers loading routes for the selected airport -->
            <Button Content="Confirm"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="18,0"
                    Style="{StaticResource ConfirmButtonStyle}"
                    Click="AirportConfirmClick"/>

            <!-- reset clears selection and screen output -->
            <Button Content="Reset"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Padding="18,0"
                    Style="{StaticResource ResetButtonStyle}"
                    Click="ResetClick"/>
        </Grid>

        <!-- list of destinations/routes returned for the selected airport -->
        <GroupBox Grid.Row="2"
                  Header="Available Routes"
                  Style="{StaticResource CardGroupBoxStyle}">
            <!-- displaymemberpath shows the destinationdisplay property from each route object -->
            <!-- selectionchanged runs when the user picks a destination in the list -->
            <ListBox x:Name="AirportRoutesList"
                     SelectionChanged="RoutesListSelection"
                     Style="{StaticResource RoutesListBoxStyle}"
                     DisplayMemberPath="DestinationDisplay"/>
        </GroupBox>

        <!-- details area showing airport info, route info, and prediction info -->
        <GroupBox Grid.Row="3"
                  Header="Selected Route Details"
                  Margin="0,10,0,10"
                  Style="{StaticResource CardGroupBoxStyle}">
            <StackPanel>
                <!-- these textblocks are updated in code behind using inlines or text -->
                <TextBlock x:Name="textAirportInfo"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight" />

                <TextBlock x:Name="textRouteInfo"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight" />

                <TextBlock x:Name="textPredictionInfo"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight" />
            </StackPanel>
        </GroupBox>

        <!-- navigation buttons at the bottom -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- back closes this window and returns to previous screen -->
            <Button Content="Back"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource PrimaryMenuButtonStyle}"
                    Click="BackClick"/>

            <!-- exit closes the full application -->
            <Button Content="Exit"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource ExitButtonStyle}"
                    Click="ExitClick"/>
        </Grid>
    </Grid>
</Window>
