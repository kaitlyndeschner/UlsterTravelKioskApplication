<Window x:Class="UlsterTravelKioskApplication.UI.Screens.DestinationsScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UlsterTravelKioskApplication.UI.Screens"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="Recommended Destinations Screen"
        Height="450"
        Width="800"
        Background="#FFF2F4F6">

    <Window.Resources>

        <!-- colour palette used across the app so the ui looks consistent -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3F6178"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5F7F92"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2F4C5C"/>

        <!-- surface colours for cards and borders -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD2D9E0"/>

        <!-- text colours for main and secondary text -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7280"/>

        <!-- confirm button colours so confirm actions stand out -->
        <SolidColorBrush x:Key="ConfirmBrush" Color="#4A766D"/>
        <SolidColorBrush x:Key="ConfirmHoverBrush" Color="#5A8A80"/>
        <SolidColorBrush x:Key="ConfirmPressedBrush" Color="#3B5E57"/>

        <!-- shadow used on cards so content feels lifted off the background -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="3"
                          Opacity="0.18"/>

        <!-- reset button colours used for clearing the screen -->
        <SolidColorBrush x:Key="ResetBrush" Color="#556A73"/>
        <SolidColorBrush x:Key="ResetHoverBrush" Color="#667D87"/>
        <SolidColorBrush x:Key="ResetPressedBrush" Color="#44565D"/>

        <!-- exit button colours used for closing the app -->
        <SolidColorBrush x:Key="ExitBrush" Color="#4F3E46"/>
        <SolidColorBrush x:Key="ExitHoverBrush" Color="#604B55"/>
        <SolidColorBrush x:Key="ExitPressedBrush" Color="#3A2F35"/>

        <!-- base button style reused for back/confirm/reset/exit to avoid repeating properties -->
        <Style x:Key="PrimaryMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#2B4553"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- rounded border makes buttons match the modern theme -->
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <!-- triggers change the button colour when hovering/pressing/disabled -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- confirm style inherits base button then overrides colours -->
        <Style x:Key="ConfirmButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ConfirmBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ConfirmPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- reset style inherits base button then overrides colours -->
        <Style x:Key="ResetButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ResetBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ResetPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ResetHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ResetPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- exit style inherits base button then overrides colours -->
        <Style x:Key="ExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ExitBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ExitPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- combobox style keeps dropdowns consistent across screens -->
        <Style x:Key="ComboBoxModernStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- groupbox template makes sections look like cards with rounded corners and shadow -->
        <Style x:Key="CardGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Effect="{StaticResource CardShadow}"
                                Padding="14"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- header displayed as small label above the content -->
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="2,0,0,10"/>

                                <ContentPresenter Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- listbox styling to match the card theme -->
        <Style x:Key="RoutesListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

    </Window.Resources>

    <!-- main layout grid controls spacing and vertical sections -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- title -->
            <RowDefinition Height="Auto"/>
            <!-- selector row -->
            <RowDefinition Height="*"/>
            <!-- list -->
            <RowDefinition Height="Auto"/>
            <!-- details -->
            <RowDefinition Height="Auto"/>
            <!-- back/exit -->
        </Grid.RowDefinitions>

        <!-- screen title with an icon so it matches other screens -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       Text="&#xE774;"
                       FontSize="20"
                       Margin="0,0,8,0"/>
            <TextBlock Text="Destinations"
                       FontSize="22"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <!-- selector row lets the user choose an option then confirm or reset -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- combobox stretches -->
                <ColumnDefinition Width="Auto"/>
                <!-- confirm -->
                <ColumnDefinition Width="Auto"/>
                <!-- reset -->
            </Grid.ColumnDefinitions>

            <!-- comboboxDestinations will be filled from code-behind (itemsource) -->
            <!-- selectedvaluepath="." means the selected value is the whole object -->
            <ComboBox x:Name="comboboxDestinations"
                      Style="{StaticResource ComboBoxModernStyle}"
                      SelectedValuePath="."/>

            <!-- confirm button triggers code-behind to load routes for the selected destination -->
            <Button Content="Confirm"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="18,0"
                    Style="{StaticResource ConfirmButtonStyle}"
                    Click="DestinationsConfirmClick"/>

            <!-- reset button clears selection and UI fields -->
            <Button Content="Reset"
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Padding="18,0"
                    Style="{StaticResource ResetButtonStyle}"
                    Click="ResetClick"/>
        </Grid>

        <!-- list of available routes returned from the confirm action -->
        <GroupBox Grid.Row="2"
                  Header="Available Routes"
                  Style="{StaticResource CardGroupBoxStyle}">
            <!-- displaymemberpath shows route.RouteDisplay instead of the object name -->
            <!-- selectionchanged triggers code-behind to show details and predictions -->
            <ListBox x:Name="DestinationsList"
                     DisplayMemberPath="RouteDisplay"
                     SelectionChanged="DestinationSelection"
                     Style="{StaticResource RoutesListBoxStyle}"/>
        </GroupBox>

        <!-- details section shows the selected destination, route details, and prediction info -->
        <GroupBox Grid.Row="3"
                  Header="Selected Route Details"
                  Margin="0,10,0,10"
                  Style="{StaticResource CardGroupBoxStyle}">
            <StackPanel>
                <!-- text blocks are updated in code-behind using inlines to style labels/bold text -->
                <TextBlock x:Name="textDestinationsInfo"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight" />

                <TextBlock x:Name="textDestinationsRouteInfo"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight" />

                <TextBlock x:Name="textDelayPredictionInfo"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight" />
            </StackPanel>
        </GroupBox>

        <!-- navigation buttons at the bottom so the user can return or exit -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- back closes this window and returns to the previous screen -->
            <Button Content="Back"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource PrimaryMenuButtonStyle}"
                    Click="BackClick"/>

            <!-- exit closes the whole application -->
            <Button Content="Exit"
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource ExitButtonStyle}"
                    Click="ExitClick"/>
        </Grid>
    </Grid>
</Window>