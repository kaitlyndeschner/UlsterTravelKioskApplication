<Window x:Class="UlsterTravelKioskApplication.UI.Screens.Admin.LoginScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UlsterTravelKioskApplication.UI.Screens.Admin"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Admin Login"
        Height="450"
        Width="800"
        Background="#FFF2F4F6">

    <!-- resources for colours and reusable styles for this login screen -->
    <Window.Resources>

        <!-- colour palette used across the application -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3F6178"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5F7F92"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2F4C5C"/>

        <!-- card background and borders -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD2D9E0"/>

        <!-- text colours for headings and helper text -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7280"/>

        <!-- confirm button colour scheme to show a positive action -->
        <SolidColorBrush x:Key="ConfirmBrush" Color="#4A766D"/>
        <SolidColorBrush x:Key="ConfirmHoverBrush" Color="#5A8A80"/>
        <SolidColorBrush x:Key="ConfirmPressedBrush" Color="#3B5E57"/>

        <!-- reusable shadow for the login card -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="3"
                          Opacity="0.18"/>

        <!-- exit button colour scheme to show a destructive action -->
        <SolidColorBrush x:Key="ExitBrush" Color="#4F3E46"/>
        <SolidColorBrush x:Key="ExitHoverBrush" Color="#604B55"/>
        <SolidColorBrush x:Key="ExitPressedBrush" Color="#3A2F35"/>

        <!-- base button style used on this screen -->
        <Style x:Key="PrimaryMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#2B4553"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <!-- custom template gives rounded corners and hover/press effects -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- confirm button inherits base style but uses confirm colours -->
        <Style x:Key="ConfirmButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ConfirmBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ConfirmPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- exit style inherits base but uses exit colours -->
        <Style x:Key="ExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ExitBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ExitPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- textbox style to keep inputs consistent across screens -->
        <Style x:Key="TextBoxModernStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- passwordbox style matches textbox style but hides typed characters -->
        <Style x:Key="PasswordBoxModernStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- card container style to centre the login form -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

    </Window.Resources>

    <!-- main layout grid: title at top, login form in middle, buttons at bottom -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- title section -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,6,0,16">
            <TextBlock Text="Ulster Travel Kiosk"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,2"/>
            <TextBlock Text="Admin Login"
                       HorizontalAlignment="Center"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- login card holds the username and password inputs -->
        <Border Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Width="320">

                <TextBlock Text="Please enter your credentials."
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- username input -->
                <TextBlock Text="Username"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtUsername"
                         Style="{StaticResource TextBoxModernStyle}"
                         Margin="0,3,0,12"/>

                <!-- password input -->
                <TextBlock Text="Password"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="SemiBold"/>

                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource PasswordBoxModernStyle}"
                             Margin="0,3,0,6"/>

                <!-- error label for invalid login messages -->
                <TextBlock x:Name="lblError"
                           Foreground="#8B3A3A"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- bottom row buttons: back, confirm login, and exit app -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Back"
                    Grid.Column="0"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource PrimaryMenuButtonStyle}"
                    Click="BackClick"/>

            <Button Content="Confirm"
                    Grid.Column="1"
                    Width="150"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Style="{StaticResource ConfirmButtonStyle}"
                    Click="ConfirmClick"/>

            <Button Content="Exit"
                    Grid.Column="2"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource ExitButtonStyle}"
                    Click="ExitClick"/>
        </Grid>

    </Grid>
</Window>