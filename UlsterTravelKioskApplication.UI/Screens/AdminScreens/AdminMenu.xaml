<Window x:Class="UlsterTravelKioskApplication.UI.Screens.Admin.AdminMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UlsterTravelKioskApplication.UI.Screens.Admin"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="Administrative Screen"
        Height="450"
        Width="800"
        Background="#FFF2F4F6">

    <!-- shared styles and brushes used by this screen -->
    <Window.Resources>

        <!-- colour palette used across admin screens -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3F6178"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5F7F92"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2F4C5C"/>

        <!-- background and border colours for card-style layout -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD2D9E0"/>

        <!-- text colours for headings and helper text -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7280"/>

        <!-- reusable drop shadow for card containers -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="3"
                          Opacity="0.18"/>

        <!-- exit button colour scheme -->
        <SolidColorBrush x:Key="ExitBrush" Color="#4F3E46"/>
        <SolidColorBrush x:Key="ExitHoverBrush" Color="#604B55"/>
        <SolidColorBrush x:Key="ExitPressedBrush" Color="#3A2F35"/>

        <!-- primary menu button style used for main actions -->
        <Style x:Key="PrimaryMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#2B4553"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <!-- custom rounded button template -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>

                        <!-- visual feedback for hover, press, and disabled states -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border"
                                        Property="Opacity"
                                        Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- exit button inherits primary style but uses darker colours -->
        <Style x:Key="ExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ExitBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ExitPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- card-style container used to group menu buttons -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- small help button style used in top-right corner -->
        <Style x:Key="HelpButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#2B4553"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <!-- simplified rounded button template -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border"
                                        Property="Opacity"
                                        Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- main layout grid with header, content, and footer -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- help button positioned in the top-right corner -->
        <Button Grid.Row="0"
                Content="Help"
                Style="{StaticResource HelpButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="HelpClick"/>

        <!-- screen title and subtitle -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,16">
            <TextBlock Text="Ulster Travel Kiosk"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,2"/>
            <TextBlock Text="Administrative Menu"
                       HorizontalAlignment="Center"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- central card containing admin menu options -->
        <Border Grid.Row="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Width="280">
                <TextBlock Text="Please select an option to proceed."
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <!-- navigation buttons for admin features -->
                <Button Content="Logging System"
                        Style="{StaticResource PrimaryMenuButtonStyle}"
                        Click="LoggingSystemClick"/>
                <Button Content="Data Management"
                        Style="{StaticResource PrimaryMenuButtonStyle}"
                        Click="DataManagementClick"/>
                <Button Content="Admin Settings"
                        Style="{StaticResource PrimaryMenuButtonStyle}"
                        Click="AdminSettingsClick"/>
            </StackPanel>
        </Border>

        <!-- bottom navigation area for back and exit -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Back"
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource PrimaryMenuButtonStyle}"
                    Click="BackClick"/>

            <Button Content="Exit"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource ExitButtonStyle}"
                    Click="ExitClick"/>
        </Grid>

    </Grid>
</Window>
