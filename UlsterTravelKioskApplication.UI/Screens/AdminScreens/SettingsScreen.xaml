<Window x:Class="UlsterTravelKioskApplication.UI.Screens.Admin.SettingsScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UlsterTravelKioskApplication.UI.Screens.Admin"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="SettingsScreen"
        Height="650"
        Width="800"
        Background="#FFF2F4F6">

    <!-- resources for colours and reusable styles for this settings screen -->
    <Window.Resources>

        <!-- colour palette -->
        <SolidColorBrush x:Key="AccentBrush" Color="#3F6178"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5F7F92"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#2F4C5C"/>

        <!-- background and border colours for card layout -->
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD2D9E0"/>

        <!-- text colours used for headings and helper labels -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1F2937"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF6B7280"/>

        <!-- confirm button colours (used for save/confirm actions) -->
        <SolidColorBrush x:Key="ConfirmBrush" Color="#4A766D"/>
        <SolidColorBrush x:Key="ConfirmHoverBrush" Color="#5A8A80"/>
        <SolidColorBrush x:Key="ConfirmPressedBrush" Color="#3B5E57"/>

        <!-- shadow used on the card container -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="14"
                          ShadowDepth="3"
                          Opacity="0.18"/>

        <!-- exit button colours (used for shutting down the app) -->
        <SolidColorBrush x:Key="ExitBrush" Color="#4F3E46"/>
        <SolidColorBrush x:Key="ExitHoverBrush" Color="#604B55"/>
        <SolidColorBrush x:Key="ExitPressedBrush" Color="#3A2F35"/>

        <!-- base button style used for back/confirm/exit -->
        <Style x:Key="PrimaryMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="#2B4553"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

            <!-- custom template gives rounded corners and hover/press colours -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- password input base style so passwordboxes look consistent -->
        <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- confirm button style uses the confirm colours -->
        <Style x:Key="ConfirmButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ConfirmBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ConfirmPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ConfirmPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- exit button style uses the exit colours -->
        <Style x:Key="ExitButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource ExitBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ExitPressedBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource ExitPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- textbox style used for username and api key inputs -->
        <Style x:Key="TextBoxModernStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- passwordbox style inherits the password input base style -->
        <Style x:Key="PasswordBoxModernStyle" TargetType="PasswordBox"
               BasedOn="{StaticResource PasswordInputStyle}"/>

        <!-- card container style to centre the settings form -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

    </Window.Resources>

    <!-- main layout: title on top, settings card in middle, buttons on bottom -->
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- title area -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,6,0,16">
            <TextBlock Text="Ulster Travel Kiosk"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Text="Settings"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <!-- settings card holds username and api credentials -->
        <Border Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Width="420">

                <!-- username input (optional) -->
                <TextBlock Text="New Admin Username (leave blank to keep current):"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="txtUsername"
                         Style="{StaticResource TextBoxModernStyle}"
                         Margin="0,3,0,12"/>

                <!-- api key input (optional) -->
                <TextBlock Text="API Key (leave blank to keep current):"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="txtApiKey"
                         Style="{StaticResource TextBoxModernStyle}"
                         Margin="0,3,0,12"/>

                <!-- api secret input (optional) -->
                <TextBlock Text="API Secret (leave blank to keep current):"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <PasswordBox x:Name="txtApiSecret"
                             Style="{StaticResource PasswordBoxModernStyle}"
                             Margin="0,3,0,12"/>

                <!-- change password section (all three fields required to change) -->
                <TextBlock Text="Current Password (required to change password):"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <PasswordBox x:Name="txtCurrentPassword"
                             Style="{StaticResource PasswordBoxModernStyle}"
                             Margin="0,3,0,12"/>

                <TextBlock Text="New Password (leave blank to keep current):"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <PasswordBox x:Name="txtNewPassword"
                             Style="{StaticResource PasswordBoxModernStyle}"
                             Margin="0,3,0,12"/>

                <TextBlock Text="Confirm New Password:"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <PasswordBox x:Name="txtConfirmPassword"
                             Style="{StaticResource PasswordBoxModernStyle}"/>
            </StackPanel>
        </Border>

        <!-- bottom buttons for navigation and saving -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Back"
                    Grid.Column="0"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource PrimaryMenuButtonStyle}"
                    Click="BackClick"/>

            <Button Content="Confirm"
                    Grid.Column="1"
                    Width="150"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Style="{StaticResource ConfirmButtonStyle}"
                    Click="ConfirmClick"/>

            <Button Content="Exit"
                    Grid.Column="2"
                    Width="90"
                    Margin="5"
                    Style="{StaticResource ExitButtonStyle}"
                    Click="ExitClick"/>
        </Grid>

    </Grid>
</Window>