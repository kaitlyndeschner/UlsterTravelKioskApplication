{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build (regenerate WPF .g.cs)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/UlsterTravelKioskApplicationFULLPROJECT.sln",
        "--nologo",
        "-v",
        "quiet"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}